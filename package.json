{
  "name": "@atheory-ai/skillex-packs",
  "version": "0.0.0",
  "private": true,
  "description": "Canonical and community skillex pack registry",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atheory-ai/skillex-packs.git"
  },
  "workspaces": [
    "ecosystems/*"
  ],
  "scripts": {
    "doctor": "skillex doctor",
    "refresh": "skillex refresh",
    "validate": "skillex test validate",
    "test": "node --test test/*.test.mjs",
    "lint:packs": "node scripts/lint-pack.mjs",
    "build:pack": "node scripts/build-pack.mjs",
    "build:manifest": "node scripts/build-manifest.mjs",
    "check:packs": "node scripts/lint-pack.mjs && node scripts/build-manifest.mjs --check"
  },
  "devDependencies": {
    "@atheory-ai/skillex": "^0.7.0",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
